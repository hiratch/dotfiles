pi=4*a(1)

define rad(x) {
  return x * pi / 180
}

define deg(x) {
  return x * 180 / pi
}

define tan(x) {
  return s(x) / c(x)
}

define t(x) {
  return tan(x)
}

define sin(x) { return s(x) }
define cos(x) { return c(x) }
define tan(x) { return t(x) }

define hypot(x, y) { return ( sqrt( x^2 + y^2 ) ) }

define feet2meter(x) { return 0.3048 * x }
define meter2feet(x) { return 3.28084* x }

define nm2meter(x) { return 1852 * x }
define meter2nm(x) { return 0.0005399568 * x }

define ft_nm2deg(y, x) {
    return deg(a(feet2meter(y) / nm2meter(x)))
}

define mach_from_celsius(t) {
    return 331.5 + 0.6 * t
}

define meter_per_sec2kt(v) {
    return 1.94384 * v
}

define kt2meter_per_sec(v) {
    return 0.514444 * v
}

/*
 * 度分形式 (例: 34度37.6分 -> 3437.6) を
 * 10進数の度 (例: 34.6266...) に変換します。
 * dms: degree minute second
 * dec: decimal
 */
define dms2dec(dms) {
    auto temp_scale, deg, min;

    /* 現在のscaleを保存 */
    temp_scale = scale;

    /* 整数部分（度）を取得するためにscaleを0に設定 */
    scale = 0;
    deg = dms / 100; /* これで整数除算になり、34が取得できる */

    /* scaleを元の設定に戻す */
    scale = temp_scale;

    /* 分の部分を取得 (例: 3437.6 - (34 * 100) = 37.6) */
    min = dms - (deg * 100);

    /* 度 + (分 / 60) を計算して返す */
    return (deg + min / 60);
}


/*
 * 10進数の度 (例: 34.6266...) を
 * 度分形式 (例: 3437.6) に変換します。
 */
define dec2dms(dec) {
    auto temp_scale, deg, min;

    /* 計算用に一時的に現在のscaleを保存 */
    temp_scale = scale;

    /* 整数部分（度）を取得するためにscaleを0にする */
    scale = 0;
    deg = dec / 1;

    /* scaleを元に戻して小数点以下の計算を行う */
    scale = temp_scale;
    min = (dec - deg) * 60;

    /* 度*100 + 分 の形式で返す */
    return (deg * 100 + min);
}

define void help() {
    print "--- My Functions ---\n"
    print "  pi              \n"
    print "  rad(x)          : convert x[deg] to radian\n"
    print "  deg(x)          : convert x[rad] to degree\n"
    print "  s(x) = sin(x)   : x [rad]\n"
    print "  c(x) = cos(x)   : x [rad]\n"
    print "  t(x) = tan(x)   : x [rad]\n"
    print "  t(x) = tan(x)   : x [rad]\n"
    print "  hypot(x, y)     : hypot()\n"
    print "  feet2meter(x)   : cconvert the numbern\n"
    print "  meter2feet(x)   : cconvert the numbern\n"
    print "  nm2meter(x)     : cconvert the numbern\n"
    print "  meter2nm(x)     : cconvert the numbern\n"
    print "  ft_nm2deg(y, x) : y[ft], x[nm]\n"
    print "  mach_from_celsius(t) : t[K]\n"
    print "  meter_per_sec2kt(v)  : v[m/s]\n"
    print "  kt2meter_per_sec(v)  : v[kt]\n"
    print "  dms2dec(dms)    : dgree minute second -> decimal\n"
    print "  dec2dms(dms)    : deciman -> dgree minute second\n"
    print "--------------------\n"
}

/* ついでに短い名前でも呼べるようにしておくと便利 */
define void h() {
    help()
}

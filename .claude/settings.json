{
  "effortLevel": "high",
  "permissions": {
    "deny": [
      "Read(.env*)",
      "Edit(.env*)",
      "Write(.env*)",
      "Bash(cat .env*)",
      "Bash(less .env*)",
      "Bash(more .env*)",
      "Bash(head .env*)",
      "Bash(tail .env*)",
      "Bash(source .env*)",
      "Bash(. .env*)"
    ]
  }
}

{
  "permissions": {
    "deny": [
      "Read(.env*)",
      "Edit(.env*)",
      "Write(.env*)",
      "Bash(cat .env*)",
      "Bash(less .env*)",
      "Bash(more .env*)",
      "Bash(head .env*)",
      "Bash(tail .env*)",
      "Bash(source .env*)",
      "Bash(. .env*)"
    ]
  },
  "model": "opus[1m]",
  "enabledPlugins": {
    "slack@claude-plugins-official": true
  },
  "effortLevel": "xhigh",
  "tui": "fullscreen",
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true
}
